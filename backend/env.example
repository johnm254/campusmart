# ── DATABASE CONFIGURATION (SUPABASE) ────────────────────────────────────
# Use port 6543 (Transaction pooler) for best results with many connections
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-ID].supabase.co:6543/postgres?sslmode=require
DB_TYPE=postgres

# ── ALTERNATIVE CONFIGURATION (MySQL/HostPinnacle) ───────────────────────
# Uncomment if using MySQL/HostPinnacle/cPanel
# DB_TYPE=mysql
# DB_HOST=localhost
# DB_PORT=3306
# DB_USER=your_db_username
# DB_PASS=your_db_password
# DB_NAME=your_db_name

# ── SERVER CONFIGURATION ────────────────────────────────────────────────
PORT=5000
JWT_SECRET=your_jwt_secret_key_here
FRONTEND_URL=http://localhost:5173

# ── EMAIL CONFIGURATION (GMAIL) ─────────────────────────────────────────
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-google-app-password

# ── ADMIN SETTINGS ──────────────────────────────────────────────────────
ADMIN_SECRET=your_admin_secret_key
X_ADMIN_SECRET=your_admin_secret_key

# ── MPESA MPESA SETTINGS ──────────────────────────────────────────────
MPESA_SHORTCODE=your_mpesa_shortcode
MPESA_CONSUMER_KEY=your_mpesa_consumer_key
MPESA_CONSUMER_SECRET=your_mpesa_consumer_secret
MPESA_PASSKEY=your_mpesa_passkey
MPESA_CALLBACK_URL=https://your-api-url.onrender.com/api/mpesa/callback
